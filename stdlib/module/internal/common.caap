      "evaluate-capture-with" evaluate-capture-with
      "unit-template" unit-template
      "replace-one" replace-one
      "erase-node" erase-node)
    (ctfe-compiler-register-value
      compiler
      "stdlib.module.internal.common"
      module-helpers-exports)
    (ctfe-compiler-register-value
      compiler
      "stdlib.module.internal.prelude-bindings"
      module-helpers-exports)
    module-helpers-exports))
