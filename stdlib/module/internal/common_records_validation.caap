(bind (
  (validation-exports (map-of))
  ;; --- Base assertion helper ---
  (assert-record
    (lambda (entry predicate message code)
      (if (predicate entry)
        entry
        (runtime-error (string-concat-many code ": " message)))))
  (field-string?
    (lambda (entry key)
      (and
        (contains entry key)
        (value-is-string (get entry key null)))))
  (field-list?
    (lambda (entry key)
      (and
        (contains entry key)
        (value-is-list (get entry key null)))))
  (field-map?
    (lambda (entry key)
      (and
        (contains entry key)
        (value-is-map (get entry key null)))))
  (field-bool?
    (lambda (entry key)
      (and
        (contains entry key)
        (value-is-bool (get entry key null)))))
  (optional-field-bool?
    (lambda (entry key)
      (or
        (not (contains entry key))
        (value-is-bool (get entry key null)))))
  (append-unique-string
    (lambda (items seen value)
      (if
        (and
          (value-is-string value)
          (not (eq value ""))
          (not (contains seen value)))
        (do
          (assoc seen value true)
          (append items value)))))
  ;; --- Predicates ---
  (runtime-model-record?
    (lambda (entry)
      (and
        (value-is-map entry)
        (field-string? entry "module")
        (field-list? entry "imports")
        (field-map? entry "provenance")
        (field-list? entry "publics"))))
  (import-record?
    (lambda (entry)
      (and
        (value-is-map entry)
        (field-string? entry "kind")
        (field-string? entry "module")
        (field-string? entry "source")
        (field-string? entry "local")
        (field-bool? entry "synthetic")
        (optional-field-bool? entry "syntax")
        (contains entry "node"))))
  (export-record?
    (lambda (entry)
      (and
        (value-is-map entry)
        (field-string? entry "local")
        (field-string? entry "public")
        (contains entry "node"))))
  (raw-record?
    (lambda (entry)
      (and
        (value-is-map entry)
        (field-string? entry "kind")
        (contains entry "node"))))
  (scan-record?
    (lambda (entry)
      (and
        (value-is-map entry)
        (field-list? entry "raw")
        (field-list? entry "strip")
        (contains entry "errors"))))
  (manifest-record?
    (lambda (entry)
      (and
        (value-is-map entry)
        (field-list? entry "modules")
        (field-list? entry "imports")
        (field-list? entry "exports")
        (field-list? entry "strip")
        (contains entry "errors"))))
  (summary-record?
    (lambda (entry)
      (and
        (value-is-map entry)
        (field-string? entry "module")
        (field-list? entry "imports"))))
  (error-record?
    (lambda (entry)
      (and (value-is-map entry) (field-string? entry "error"))))
  (provenance-record?
    (lambda (entry)
      (if (not (value-is-map entry))
        false
        (bind (
          (kind (get entry "kind" null))
        )
          (and
            (value-is-string kind)
            (field-string? entry "local")
            (if (eq kind "imported")
              (and
                (field-string? entry "module")
                (field-string? entry "source"))
              (if (eq kind "host_service")
                (and
                  (field-string? entry "library")
                  (field-string? entry "export")
                  (field-string? entry "phase")
                  (field-string? entry "effect")
                  (field-bool? entry "pure")
                  (contains entry "policy"))
                true)))))))
  (interface-record?
    (lambda (entry)
      (and
        (value-is-map entry)
        (field-string? entry "module")
        (field-map? entry "exports")
        (field-map? entry "provenance"))))
  (provider-record?
    (lambda (entry)
      (if (not (value-is-map entry))
        false
        (bind (
          (kind (get entry "provider_kind" null))
        )
          (if (eq kind "template")
            (contains entry "template")
            (if (eq kind "host-service")
              (and
                (field-string? entry "library")
                (field-map? entry "export_names")
                (field-map? entry "runtime_values")
                (field-map? entry "compile_time_values"))
              false))))))
  ;; --- Assertion wrappers ---
  (assert-runtime-model
    (lambda (entry)
      (assert-record
        entry
        runtime-model-record?
        "invalid module runtime model record"
        "stdlib.module.record.runtime_model.invalid")))
  (assert-import-record
    (lambda (entry)
      (assert-record
        entry
        import-record?
        "invalid module import record"
        "stdlib.module.record.import.invalid")))
  (assert-export-record
    (lambda (entry)
      (assert-record
        entry
        export-record?
        "invalid module export record"
        "stdlib.module.record.export.invalid")))
  (assert-raw-record
    (lambda (entry)
      (assert-record
        entry
        raw-record?
        "invalid raw module scan record"
        "stdlib.module.record.raw.invalid")))
  (assert-scan-record
    (lambda (entry)
      (assert-record
        entry
        scan-record?
        "invalid module scan result record"
        "stdlib.module.record.scan.invalid")))
  (assert-manifest
    (lambda (entry)
      (assert-record
        entry
        manifest-record?
        "invalid module manifest record"
        "stdlib.module.record.manifest.invalid")))
  (assert-summary
    (lambda (entry)
      (assert-record
        entry
        summary-record?
        "invalid module summary record"
        "stdlib.module.record.summary.invalid")))
  (assert-provenance
    (lambda (entry)
      (assert-record
        entry
        provenance-record?
        "invalid module provenance record"
        "stdlib.module.record.provenance.invalid")))
  (assert-interface
    (lambda (entry)
      (assert-record
        entry
        interface-record?
        "invalid module interface record"
        "stdlib.module.record.interface.invalid")))
  (assert-provider
    (lambda (entry)
      (assert-record
        entry
        provider-record?
        "invalid module provider record"
        "stdlib.module.record.provider.invalid")))
)
  (do
    (assoc-many
      validation-exports
      "assert-record" assert-record
      "append-unique-string" append-unique-string
      "runtime-model-record?" runtime-model-record?
      "import-record?" import-record?
      "export-record?" export-record?
      "raw-record?" raw-record?
      "scan-record?" scan-record?
      "manifest-record?" manifest-record?
      "summary-record?" summary-record?
      "error-record?" error-record?
      "provenance-record?" provenance-record?
      "interface-record?" interface-record?
      "provider-record?" provider-record?
      "assert-runtime-model" assert-runtime-model
      "assert-import-record" assert-import-record
      "assert-export-record" assert-export-record
      "assert-raw-record" assert-raw-record
      "assert-scan-record" assert-scan-record
      "assert-manifest" assert-manifest
      "assert-summary" assert-summary
      "assert-provenance" assert-provenance
      "assert-interface" assert-interface
      "assert-provider" assert-provider)
    (ctfe-compiler-register-value
      compiler
      "stdlib.module.internal.common-records-validation"
      validation-exports)
    validation-exports))
