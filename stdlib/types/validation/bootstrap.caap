(module "stdlib.types.validation")

(import-namespace "stdlib.sequence" "sequence")

(import-namespace "stdlib.types.core" "core")

(export "stdlib.types.validation")

(bind (
  (exports (map-of))
  (semantics (map-of))
  (get-any (get sequence "get" null))
  (is-null? (get sequence "is-null?" null))
  (get-or-null (get sequence "get-or-null" null))
  (nonempty-str? (get sequence "nonempty-str?" null))
  (pure-semantics (get core "pure-semantics" null))
  (each (get sequence "each" null))
  (fold-left (get sequence "fold-left" null))
  (copy (get sequence "copy" null))
  (type-key (get core "type-key" null))
  (primitive-key (get core "primitive-key" null))
  (struct-key (get core "struct-key" null))
  (enum-key (get core "enum-key" null))
  (alias-key (get core "alias-key" null))
  (newtype-key (get core "newtype-key" null))
  (array-key (get core "array-key" null))
  (type-param-key (get core "type-param-key" null))
  (generic-key (get core "generic-key" null))
  (require-name
    (lambda (label value)
      (if (not (nonempty-str? value))
        (runtime-error
          (string-concat-many label " must be a non-empty string"))
        value)))
  (require-positive-int
    (lambda (label value)
      (if (or (not (value-is-int value)) (not (value-lt 0 value)))
        (runtime-error
          (string-concat-many label " must be a positive integer"))
        value)))
  (require-map
    (lambda (label value)
      (if (not (value-is-map value))
        (runtime-error (string-concat-many label " must be a map"))
        value)))
  (bool-string
    (lambda (value)
      (if value
        "true"
        "false")))
  (path-contains?
    (lambda (path key)
      (fold-left
        path
        false
        (lambda (found entry)
          (or found (eq entry key))))))
  (path-with
    (lambda (path key)
      (bind (
        (next-path (copy path))
      )
        (do
          (append next-path key)
          next-path))))
  (cache-validated-type
    (lambda (cache key type-map)
      (do
        (assoc cache key type-map)
        type-map)))
  (validate-field-list
    (lambda (validate-type-impl fields seen path cache)
      (do
        (each fields
          (lambda (raw-field)
            (bind (
              (field (require-map "struct field" raw-field))
            )
              (bind (
                (field-name
                  (require-name
                    "struct field name"
                    (get-or-null field "name")))
                (field-type (get-or-null field "type"))
              )
                (do
                  (if (is-null? field-type)
                    (runtime-error
                      (string-concat-many
                        "struct field "
                        field-name
                        " is missing a type"))
                    null)
                  (if (contains seen field-name)
                    (runtime-error
                      (string-concat-many
                        "duplicate struct field name: "
                        field-name))
                    null)
                  (validate-type-impl
                    validate-type-impl
                    field-type
                    path
                    cache)
                  (assoc seen field-name true))))))
        fields)))
  (validate-enum-variants
    (lambda (variants seen)
      (do
        (each variants
          (lambda (raw-variant)
            (bind (
              (variant
                (require-map "enum variant" raw-variant))
            )
              (bind (
                (variant-name
                  (require-name
                    "enum variant name"
                    (get-or-null variant "name")))
                (variant-value
                  (get-or-null variant "value"))
              )
                (do
                  (if (contains seen variant-name)
                    (runtime-error
                      (string-concat-many
                        "duplicate enum variant name: "
                        variant-name))
                    null)
                  (if (not (value-is-int variant-value))
                    (runtime-error
                      (string-concat-many
                        "enum variant "
                        variant-name
                        " must declare an integer value"))
                    null)
                  (assoc seen variant-name true))))))
        variants)))
  (function-param-key
    (lambda (key-impl params path cache)
      (fold-left
        params
        ""
        (lambda (acc param)
          (bind (
            (piece
              (type-key
                (validate-type-impl
                  key-impl
                  (get-or-null param "type")
                  path
                  cache)))
          )
            (if (eq acc "")
              piece
              (string-concat-many acc "," piece)))))))
  (function-key
    (lambda (key-impl params result path cache)
      (string-concat-many
        "function:("
        (function-param-key key-impl params path cache)
        ")->"
        (type-key (validate-type-impl key-impl result path cache)))))
  (validate-function-params
    (lambda (validate-type-impl params seen path cache)
      (do
        (each params
          (lambda (raw-param)
            (bind (
              (param
                (require-map "function param" raw-param))
              (param-name (get-or-null raw-param "name"))
              (param-type (get-or-null raw-param "type"))
            )
              (do
                (if (not (is-null? param-name))
                  (do
                    (require-name "function param name" param-name)
                    (if (contains seen param-name)
                      (runtime-error
                        (string-concat-many
                          "duplicate function param name: "
                          param-name))
                      null)
                    (assoc seen param-name true))
                  null)
                (if (is-null? param-type)
                  (runtime-error "function param is missing a type")
                  null)
                (validate-type-impl
                  validate-type-impl
                  param-type
                  path
                  cache)))))
        params)))
  (validate-type-impl
    (lambda (self type path cache)
      (bind (
        (type-map (require-map "type" type))
        (kind
          (require-name "type kind" (get-or-null type-map "kind")))
        (key
          (require-name "type key" (get-or-null type-map "key")))
      )
        (if (path-contains? path key)
          (runtime-error
            (string-concat-many
              "cyclic type reference detected at "
              key))
          null)
        (if (contains cache key)
          (get cache key null)
          (bind (
            (next-path (path-with path key))
          )
            (if (eq kind "primitive")
              (bind (
                (name
                  (require-name
                    "primitive type name"
                    (get-or-null type-map "name")))
                (category
                  (require-name
                    "primitive type category"
                    (get-or-null type-map "category")))
              )
                (do
                  (if (not (eq key (primitive-key name)))
                    (runtime-error
                      (string-concat-many "primitive type key mismatch for " name))
                    null)
                  (if (eq category "integer")
                    (do
                      (require-positive-int
                        "primitive integer bits"
                        (get-or-null type-map "bits"))
                      (if (not (value-is-bool (get-or-null type-map "signed")))
                        (runtime-error
                          (string-concat-many
                            "primitive integer "
                            name
                            " must declare signed"))
                        null))
                    (if (eq category "float")
                      (require-positive-int
                        "primitive float bits"
                        (get-or-null type-map "bits"))
                      (if
                        (or
                          (eq category "boolean")
                          (eq category "string")
                          (eq category "pointer")
                          (eq category "void"))
                        type-map
                        (runtime-error
                          (string-concat-many "unknown primitive category: " category)))))
                  (cache-validated-type cache key type-map)))
              (if (eq kind "struct")
                (bind (
                  (name
                    (require-name
                      "struct type name"
                      (get-or-null type-map "name")))
                  (fields (get-or-null type-map "fields"))
                )
                  (do
                    (if (is-null? fields)
                      (runtime-error
                        (string-concat-many "struct " name " is missing fields"))
                      null)
                    (if (not (eq key (struct-key name)))
                      (runtime-error
                        (string-concat-many "struct type key mismatch for " name))
                      null)
                    (validate-field-list self fields (map-of) next-path cache)
                    (cache-validated-type cache key type-map)))
                (if (eq kind "enum")
                  (bind (
                    (name
                      (require-name
                        "enum type name"
                        (get-or-null type-map "name")))
                    (variants
                      (get-or-null type-map "variants"))
                    (underlying
                      (get-or-null type-map "underlying"))
                  )
                    (do
                      (if (is-null? variants)
                        (runtime-error
                          (string-concat-many "enum " name " is missing variants"))
                        null)
                      (if (is-null? underlying)
                        (runtime-error
                          (string-concat-many
                            "enum "
                            name
                            " is missing an underlying type"))
                        null)
                      (if (not (eq key (enum-key name)))
                        (runtime-error
                          (string-concat-many "enum type key mismatch for " name))
                        null)
                      (self self underlying next-path cache)
                      (validate-enum-variants variants (map-of))
                      (cache-validated-type cache key type-map)))
                  (if (eq kind "alias")
                    (bind (
                      (name
                        (require-name
                          "alias type name"
                          (get-or-null type-map "name")))
                      (target
                        (get-or-null type-map "target"))
                    )
                      (do
                        (if (is-null? target)
                          (runtime-error
                            (string-concat-many
                              "alias "
                              name
                              " is missing a target type"))
                          null)
                        (if (not (eq key (alias-key name)))
                          (runtime-error
                            (string-concat-many "alias type key mismatch for " name))
                          null)
                        (self self target next-path cache)
                        (cache-validated-type cache key type-map)))
                    (if (eq kind "newtype")
                      (bind (
                        (name
                          (require-name "newtype name" (get-or-null type-map "name")))
                        (underlying
                          (get-or-null type-map "underlying"))
                      )
                        (do
                          (if (is-null? underlying)
                            (runtime-error
                              (string-concat-many
                                "newtype "
                                name
                                " is missing an underlying type"))
                            null)
                          (if (not (eq key (newtype-key name)))
                            (runtime-error
                              (string-concat-many "newtype key mismatch for " name))
                            null)
                          (self self underlying next-path cache)
                          (cache-validated-type cache key type-map)))
                      (if (eq kind "function")
                        (bind (
                          (params
                            (get-or-null type-map "params"))
                          (result
                            (get-or-null type-map "result"))
                        )
                          (do
                            (if (is-null? params)
                              (runtime-error "function type is missing params")
                              null)
                            (if (is-null? result)
                              (runtime-error "function type is missing result")
                              null)
                            (validate-function-params
                              self
                              params
                              (map-of)
                              next-path
                              cache)
                            (self self result next-path cache)
                            (if
                              (not
                                (eq key (function-key self params result next-path cache)))
                              (runtime-error "function type key mismatch")
                              null)
                            (cache-validated-type cache key type-map)))
                        (if (eq kind "array")
                          (bind (
                            (element
                              (get-or-null type-map "element"))
                            (length-val
                              (get-or-null type-map "length"))
                          )
                            (do
                              (if (is-null? element)
                                (runtime-error "array type is missing an element type")
                                null)
                              (require-positive-int "array length" length-val)
                              (self self element next-path cache)
                              (if (not (eq key (array-key element length-val)))
                                (runtime-error "array type key mismatch")
                                null)
                              (cache-validated-type cache key type-map)))
                          (if (eq kind "type_parameter")
                            (bind (
                              (name
                                (require-name
                                  "type parameter name"
                                  (get-or-null type-map "name")))
                            )
                              (do
                                (if (not (eq key (type-param-key name)))
                                  (runtime-error "type parameter key mismatch")
                                  null)
                                (cache-validated-type cache key type-map)))
                            (if (eq kind "generic")
                              (bind (
                                (base
                                  (get-or-null type-map "base"))
                                (args
                                  (get-or-null type-map "args"))
                              )
                                (do
                                  (if (is-null? base)
                                    (runtime-error "generic type is missing a base type")
                                    null)
                                  (if (is-null? args)
                                    (runtime-error "generic type is missing args")
                                    null)
                                  (self self base next-path cache)
                                  (each args
                                    (lambda (arg)
                                      (self self arg next-path cache)))
                                  (if (not (eq key (generic-key base args)))
                                    (runtime-error "generic type key mismatch")
                                    null)
                                  (cache-validated-type cache key type-map)))
                              (runtime-error
                                (string-concat-many "unknown type kind: " kind))))))))))))))))
  (validate-type
    (lambda (type)
      (validate-type-impl
        validate-type-impl
        type
        (list-of)
        (map-of))))
  (field-shape-key
    (lambda (shape-key-impl fields cache)
      (fold-left
        fields
        ""
        (lambda (acc field)
          (bind (
            (piece
              (string-concat-many
                (get-any field "name" "")
                ":"
                (shape-key-impl
                  shape-key-impl
                  (get-or-null field "type")
                  cache)))
          )
            (if (eq acc "")
              piece
              (string-concat-many acc "," piece)))))))
  (function-param-shape-key
    (lambda (shape-key-impl params cache)
      (fold-left
        params
        ""
        (lambda (acc param)
          (bind (
            (piece
              (shape-key-impl
                shape-key-impl
                (get-or-null param "type")
                cache))
          )
            (if (eq acc "")
              piece
              (string-concat-many acc "," piece)))))))
  (shape-key-impl
    (lambda (self type cache)
      (bind (
        (validated (validate-type type))
        (kind (get-or-null validated "kind"))
        (key (get-any validated "key" ""))
      )
        (if (contains cache key)
          (get cache key null)
          (bind (
            (shape
              (if (eq kind "primitive")
                (bind (
                  (category
                    (get-any validated "category" ""))
                  (bits (get-or-null validated "bits"))
                  (signed (get-or-null validated "signed"))
                )
                  (string-concat-many
                    key
                    ":"
                    category
                    ":"
                    (if (is-null? bits)
                      "-"
                      (int-to-string bits))
                    ":"
                    (if (is-null? signed)
                      "-"
                      (bool-string signed))))
                (if (eq kind "struct")
                  (bind (
                    (fields
                      (get-or-null validated "fields"))
                  )
                    (string-concat-many
                      key
                      "|"
                      (field-shape-key self fields cache)))
                  (if (eq kind "enum")
                    (string-concat-many
                      key
                      ":"
                      (self self (get-or-null validated "underlying") cache))
                    (if (eq kind "alias")
                      (string-concat-many
                        key
                        ":"
                        (self self (get-or-null validated "target") cache))
                      (if (eq kind "newtype")
                        (string-concat-many
                          key
                          ":"
                          (self self (get-or-null validated "underlying") cache))
                        (if (eq kind "function")
                          (string-concat-many
                            key
                            ":"
                            (function-param-shape-key
                              self
                              (get-or-null validated "params")
                              cache)
                            "->"
                            (self self (get-or-null validated "result") cache))
                          (string-concat-many
                            key
                            ":"
                            (self self (get-or-null validated "element") cache)
                            ":"
                            (int-to-string (get-any validated "length" 0))))))))))
          )
            (do
              (assoc cache key shape)
              shape))))))
  (type-shape-key
    (lambda (type)
      (shape-key-impl shape-key-impl type (map-of))))
  (validate-registry-order
    (lambda (registry order by-name by-key)
      (do
        (each order
          (lambda (raw-name)
            (bind (
              (name
                (require-name "registry order entry" raw-name))
              (registered (get-or-null by-name name))
            )
              (do
                (if (is-null? registered)
                  (runtime-error
                    (string-concat-many "registry is missing named entry " name))
                  null)
                (validate-type registered)
                (if (is-null? (get-or-null by-key (type-key registered)))
                  (runtime-error
                    (string-concat-many
                      "registry is missing key entry for "
                      name))
                  null)))))
        registry)))
  (validate-registry
    (lambda (registry)
      (bind (
        (registry-map
          (require-map "type registry" registry))
        (kind
          (require-name
            "registry kind"
            (get-or-null registry-map "kind")))
        (by-name
          (require-map
            "registry by_name"
            (get-or-null registry-map "by_name")))
        (by-key
          (require-map
            "registry by_key"
            (get-or-null registry-map "by_key")))
        (order (get-or-null registry-map "order"))
      )
        (do
          (if (not (eq kind "type_registry"))
            (runtime-error "registry kind must be type_registry")
            null)
          (if (is-null? order)
            (runtime-error "registry order is missing")
            null)
          (validate-registry-order registry-map order by-name by-key)
          registry-map))))
)
  (do
    (assoc-many
      semantics
      "validate-type" pure-semantics
      "validate-registry" pure-semantics
      "type-shape-key" pure-semantics)
    (assoc-many
      exports
      "validate-type" validate-type
      "validate-registry" validate-registry
      "type-shape-key" type-shape-key
      "__contract_semantics__" semantics)
    (ctfe-compiler-register-value
      compiler
      "stdlib.types.validation"
      exports)
    exports))
