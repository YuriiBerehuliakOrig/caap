; stdlib/lib/tests/test_csv.caap — smoke (salvaged module; full coverage TBD).

;; @area: text
;; @kind: unit
;; @slow: false
(use stdlib.lib.test assert_eq assert_true)
(use stdlib.lib.text.csv csv_parse csv_emit)
(do
  (bind ((r (csv_parse "a,b,c\n1,2,3")))
    (do
      (assert_true (get r "ok" false) "csv_parse ok")
      (assert_eq (size (get r "rows")) 2 "two rows")
      (assert_eq (get (get (get r "rows") 0) 1) "b" "row0 col1 = b")
      (assert_eq (get (get (get r "rows") 1) 2) "3" "row1 col2 = 3")))
  true)
