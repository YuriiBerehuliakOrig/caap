; stdlib/lib/tests/test_naming.caap — predicate naming-convention lint.

;; @area: passes
;; @kind: unit
;; @slow: false
(use stdlib.lib.test assert_eq assert_true)
(use stdlib.semantics.passes.naming check_module)
(use stdlib.semantics.passes.registry fact!)
(use stdlib.syntax.ast sym lit calln lam loc)
(use stdlib.lib.collections.sequence any?)

(do
  (bind (
    (def (lambda (nm v) (calln "bind" (list_of (lit nm) v))))
    (run (lambda (node)
      (bind ((s (list_of)))
        (do (check_module (list_of (assoc (map_of) "node" node "loc" "m")) s) s))))
    (has (lambda (s n) (any? s (lambda (f) (string_contains f n)))))
  )
    (do
      ; ── computes a boolean, no `?` -> flagged ──
      (assert_true
        (has (run (def "even"
                    (lam (list_of "n")
                      (calln "eq" (list_of (calln "int_mod" (list_of (sym "n") (lit 2)))
                                           (lit 0))))))
             "consider a `?`")
        "boolean-computing fn without `?` flagged")

      ; ── already named with `?` -> clean ──
      (assert_eq
        (size (run (def "even?"
                     (lam (list_of "n") (calln "eq" (list_of (sym "n") (lit 0)))))))
        0
        "predicate named with `?` is fine")

      ; ── a comparison-family name (eq/ne/…) is the recognized spelling ──
      (assert_eq
        (size (run (def "deep_ne"
                     (lam (list_of "a" "b") (calln "not" (list_of (sym "x")))))))
        0
        "an eq/ne-family name is not nudged toward `?`")

      ; ── a true/false SENTINEL (action returning a literal) is not a predicate ──
      (assert_eq
        (size (run (def "verify"
                     (lam (list_of "x")
                       (calln "do" (list_of (calln "work" (list_of (sym "x"))) (lit true)))))))
        0
        "an action returning a `true` sentinel is not nudged toward `?`")

      ; ── non-boolean result -> not flagged ──
      (assert_eq
        (size (run (def "inc"
                     (lam (list_of "n") (calln "int_add" (list_of (sym "n") (lit 1)))))))
        0
        "int-returning fn is not nudged")

      ; ── a boolean computed in a bind BODY (let* result) is recognized ──
      ; (lambda (n) (bind "m" (int_mod n 2) (eq m 0)))
      (assert_true
        (has (run (def "divides_two"
                    (lam (list_of "n")
                      (calln "bind"
                        (list_of (lit "m") (calln "int_mod" (list_of (sym "n") (lit 2)))
                                 (calln "eq" (list_of (sym "m") (lit 0))))))))
             "consider a `?`")
        "a predicate whose result is computed in a bind body is nudged")

      ; ── clean: a bind body returning a NON-boolean is not nudged ──
      (assert_eq
        (size (run (def "doubled"
                     (lam (list_of "n")
                       (calln "bind"
                         (list_of (lit "m") (sym "n")
                                  (calln "int_add" (list_of (sym "m") (sym "m")))))))))
        0
        "a bind body returning an int is not nudged toward `?`")

      ; ── `!` mutator is left alone ──
      (assert_eq
        (size (run (def "toggle!" (lam (list_of "x") (calln "eq" (list_of (sym "x") (lit 0)))))))
        0
        "`!` name is not asked for `?`")

      ; ── `!` rule: an IMPURE fn (per the fn_effect fact the type pass publishes)
      ; whose name lacks `!` is nudged; one already named `!` is clean ──
      (bind ((sp1 (map_of "start" 0 "end" 1 "start_line" 5 "start_col" 1
                          "end_line" 5 "end_col" 9 "path" "m.caap"))
             (impure_no_bang (ctfe_spec_with_span
                               (def "save"
                                 (lam (list_of "x")
                                   (calln "set_ref" (list_of (sym "g") (sym "x")))))
                               sp1)))
        (do
          (fact! "fn_effect" (loc impure_no_bang) "impure")
          (assert_true (has (run impure_no_bang) "consider a `!`")
            "impure fn without `!` flagged")))
      (bind ((sp2 (map_of "start" 0 "end" 1 "start_line" 7 "start_col" 1
                          "end_line" 7 "end_col" 9 "path" "m.caap"))
             (impure_bang (ctfe_spec_with_span
                            (def "save!"
                              (lam (list_of "x")
                                (calln "set_ref" (list_of (sym "g") (sym "x")))))
                            sp2)))
        (do
          (fact! "fn_effect" (loc impure_bang) "impure")
          (assert_eq (size (run impure_bang)) 0
            "impure fn already named with `!` is fine")))
      (bind ((sp3 (map_of "start" 0 "end" 1 "start_line" 9 "start_col" 1
                          "end_line" 9 "end_col" 9 "path" "m.caap"))
             (pure_fn (ctfe_spec_with_span
                        (def "calc"
                          (lam (list_of "x") (calln "int_add" (list_of (sym "x") (lit 1)))))
                        sp3)))
        (do
          (fact! "fn_effect" (loc pure_fn) "pure")
          (assert_eq (size (run pure_fn)) 0 "a pure fn is not nudged toward `!`"))))))
