; stdlib/lib/test_math.caap — in-language tests for lib/math.

;; @area: numeric
;; @kind: unit
;; @slow: false
(use stdlib.lib.test assert_eq assert_true)
(use stdlib.lib.core.math abs sign min max clamp pow gcd lcm factorial even? odd?
     pow_mod isqrt divmod ceil_div mod_inverse is_prime? gcd_list lcm_list)

(assert_eq (abs -5) 5 "abs neg")
(assert_eq (abs 5) 5 "abs pos")
(assert_eq (abs 0) 0 "abs zero")
(assert_eq (sign -9) -1 "sign neg")
(assert_eq (sign 0) 0 "sign zero")
(assert_eq (sign 9) 1 "sign pos")
(assert_eq (min 3 7) 3 "min")
(assert_eq (max 3 7) 7 "max")
(assert_eq (clamp 5 0 10) 5 "clamp in range")
(assert_eq (clamp -2 0 10) 0 "clamp below")
(assert_eq (clamp 99 0 10) 10 "clamp above")
(assert_eq (pow 2 10) 1024 "pow")
(assert_eq (pow 5 0) 1 "pow zero exp")
(assert_eq (pow 7 1) 7 "pow one")
(assert_eq (gcd 48 36) 12 "gcd")
(assert_eq (gcd 17 5) 1 "gcd coprime")
(assert_eq (gcd 0 0) 0 "gcd zero")
(assert_eq (gcd -12 8) 4 "gcd negatives")
(assert_eq (lcm 4 6) 12 "lcm")
(assert_eq (lcm 0 5) 0 "lcm zero")
(assert_eq (lcm -4 6) 12 "lcm negatives")
; divide-before-multiply: true LCM fits i64 though a*b would overflow
(assert_eq (lcm 4000000000 6000000000) 12000000000 "lcm no intermediate overflow")
(assert_eq (factorial 0) 1 "factorial zero")
(assert_eq (factorial 1) 1 "factorial one")
(assert_eq (factorial 5) 120 "factorial five")
(assert_eq (even? 4) true "even")
(assert_eq (even? 5) false "odd not even")
(assert_eq (odd? 5) true "odd")

; pow_mod — square-and-multiply, reduced each step
(assert_eq (pow_mod 2 10 1000) 24 "pow_mod 2^10 mod 1000")
(assert_eq (pow_mod 3 0 7) 1 "pow_mod exp zero")
(assert_eq (pow_mod 7 13 100) (int_mod (pow 7 13) 100) "pow_mod agrees with pow")
(assert_eq (pow_mod 10 5 1) 0 "pow_mod mod 1 is 0")
(assert_eq (pow_mod 5 3 13) 8 "pow_mod 5^3 mod 13")
; isqrt — floor of the square root
(assert_eq (isqrt 0) 0 "isqrt 0")
(assert_eq (isqrt 1) 1 "isqrt 1")
(assert_eq (isqrt 2) 1 "isqrt 2")
(assert_eq (isqrt 15) 3 "isqrt 15")
(assert_eq (isqrt 16) 4 "isqrt 16")
(assert_eq (isqrt 17) 4 "isqrt 17")
(assert_eq (isqrt 1000000) 1000 "isqrt 1e6")
; divmod — (quotient remainder)
(assert_eq (get (divmod 17 5) 0) 3 "divmod quotient")
(assert_eq (get (divmod 17 5) 1) 2 "divmod remainder")
(assert_eq (size (divmod 17 5)) 2 "divmod is a pair")

; ceil_div — ceiling of a/b (a >= 0, b > 0)
(assert_eq (ceil_div 7 3) 3 "ceil_div 7/3 = 3")
(assert_eq (ceil_div 6 3) 2 "ceil_div exact 6/3 = 2")
(assert_eq (ceil_div 1 3) 1 "ceil_div 1/3 rounds up")
(assert_eq (ceil_div 0 5) 0 "ceil_div 0 = 0")
(assert_eq (ceil_div 10 1) 10 "ceil_div by 1")
(assert_eq (ceil_div 100 7) 15 "ceil_div 100/7 = 15")
(assert_eq (ceil_div 9223372036854775807 2) 4611686018427387904 "ceil_div i64::MAX/2 no overflow")

; mod_inverse — modular inverse via extended Euclid (null when not coprime)
(assert_eq (mod_inverse 3 11) 4 "mod_inverse 3 mod 11 = 4")  ; 3*4 = 12 = 1 (mod 11)
(assert_eq (mod_inverse 10 17) 12 "mod_inverse 10 mod 17 = 12") ; 10*12 = 120 = 1 (mod 17)
(assert_eq (mod_inverse 1 7) 1 "mod_inverse 1 = 1")
(assert_eq (mod_inverse 7 7) null "mod_inverse 7 mod 7 = null (a≡0)")
(assert_eq (mod_inverse 2 4) null "mod_inverse 2 mod 4 = null (gcd 2)")
(assert_eq (mod_inverse 6 9) null "mod_inverse 6 mod 9 = null (gcd 3)")
(assert_eq (mod_inverse 7 13) 2 "mod_inverse 7 mod 13 = 2 (7*2 = 14 = 1 mod 13)")
(assert_eq (mod_inverse 14 11) (mod_inverse 3 11) "mod_inverse reduces a mod m first")

; is_prime? — deterministic Miller-Rabin (exact within the documented bound)
(assert_eq (is_prime? 2) true "is_prime? 2")
(assert_eq (is_prime? 3) true "is_prime? 3")
(assert_eq (is_prime? 97) true "is_prime? 97")
(assert_eq (is_prime? 0) false "is_prime? 0")
(assert_eq (is_prime? 1) false "is_prime? 1")
(assert_eq (is_prime? -7) false "is_prime? negative")
(assert_eq (is_prime? 4) false "is_prime? 4")
(assert_eq (is_prime? 91) false "is_prime? 91 = 7*13")
(assert_eq (is_prime? 25) false "is_prime? 25 = 5*5")
(assert_eq (is_prime? 561) false "is_prime? 561 Carmichael")  ; fools weak tests
(assert_eq (is_prime? 7919) true "is_prime? 7919 (1000th prime)")
(assert_eq (is_prime? 104729) true "is_prime? 104729 (10000th prime)")
(assert_eq (is_prime? 1000000007) true "is_prime? 1e9+7")
(assert_eq (is_prime? 1000000009) true "is_prime? 1e9+9")
(assert_eq (is_prime? 1000000005) false "is_prime? 1000000005 composite")

; gcd_list / lcm_list — fold gcd/lcm over a list
(assert_eq (gcd_list (list_of 12 18 24)) 6 "gcd_list 12,18,24 = 6")
(assert_eq (gcd_list (list_of 7)) 7 "gcd_list singleton")
(assert_eq (gcd_list (list_of 17 5)) 1 "gcd_list coprime = 1")
(assert_eq (gcd_list (list_of -12 8 4)) 4 "gcd_list negatives")
(assert_eq (lcm_list (list_of 4 6 8)) 24 "lcm_list 4,6,8 = 24")
(assert_eq (lcm_list (list_of 5)) 5 "lcm_list singleton")
(assert_eq (lcm_list (list_of 2 3 5 7)) 210 "lcm_list 2,3,5,7 = 210")
(assert_eq (lcm_list (list_of 4 0 6)) 0 "lcm_list with zero = 0")
(assert_eq (lcm_list (list_of 4000000000 6000000000)) 12000000000 "lcm_list no intermediate overflow")
