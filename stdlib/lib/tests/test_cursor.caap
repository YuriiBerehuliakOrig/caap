; stdlib/lib/tests/test_cursor.caap — in-language tests for the shared
; lib/text/cursor parser protocol. Mirrors the helper behaviours the json /
; toml / csv parsers rely on: char-at with an EOF "" sentinel, 1-based
; "line:col" location, [i0,i1) slicing, and the two {ok}-result shapes.

;; @area: text
;; @kind: unit
;; @slow: false
(use stdlib.lib.test assert_eq assert_true)
(use stdlib.lib.text.cursor
  cursor_ch cursor_pos cursor_slice parse_ok parse_fail)

(do
  ; cursor_ch — right char in range, "" at and just past EOF.
  (bind ((abc (string_chars "abc")))
    (do
      (assert_eq (cursor_ch abc 0) "a" "ch index 0")
      (assert_eq (cursor_ch abc 2) "c" "ch last index")
      ; index 3 == (size abc): one past the last char -> "" sentinel
      (assert_eq (cursor_ch abc 3) "" "ch at EOF is \"\"")
      (assert_eq (cursor_ch abc 99) "" "ch well past EOF is \"\"")))

  ; cursor_pos — 1:1 at the start, advances the line over a "\n". A 2-line
  ; string: "ab\ncd" — index 0 is line 1 col 1; the char AFTER the newline
  ; (index 3, the "c") is line 2 col 1.
  (bind ((two (string_chars "ab\ncd")))
    (do
      (assert_eq (cursor_pos two 0) "1:1" "pos at start is 1:1")
      (assert_eq (cursor_pos two 1) "1:2" "pos advances column")
      (assert_eq (cursor_pos two 2) "1:3" "pos counts the newline char itself")
      (assert_eq (cursor_pos two 3) "2:1" "pos resets to a new line after \\n")
      (assert_eq (cursor_pos two 4) "2:2" "pos advances on the second line")))

  ; cursor_slice — the chars [i0, i1) joined into a substring; empty when i0==i1.
  (bind ((hello (string_chars "hello world")))
    (do
      (assert_eq (cursor_slice hello 0 5) "hello" "slice prefix")
      (assert_eq (cursor_slice hello 6 11) "world" "slice suffix")
      (assert_eq (cursor_slice hello 2 2) "" "empty slice when i0 == i1")))

  ; parse_ok — exact {ok: true, value, i} shape. `eq` is identity on maps, so
  ; the whole-map check goes through value_eq; the keys are also probed by get.
  (bind ((okv (parse_ok 42 7)))
    (do
      (assert_true
        (value_eq okv (assoc (map_of) "ok" true "value" 42 "i" 7))
        "parse_ok map shape")
      (assert_eq (get okv "ok" false) true "parse_ok ok flag")
      (assert_eq (get okv "value" 0) 42 "parse_ok carries value")
      (assert_eq (get okv "i" 0) 7 "parse_ok carries index")))

  ; parse_fail — exact {ok: false, error: "line:col: message"} shape, the
  ; location supplied by cursor_pos (no parser tag prefix).
  (bind ((two (string_chars "ab\ncd"))
         (badv (parse_fail two 3 "boom")))
    (do
      (assert_true
        (value_eq badv (assoc (map_of) "ok" false "error" "2:1: boom"))
        "parse_fail map shape")
      (assert_eq (get badv "ok" true) false "parse_fail ok flag")
      (assert_eq (get badv "error" "") "2:1: boom"
        "parse_fail error is located 'line:col: message'")))
  true)
