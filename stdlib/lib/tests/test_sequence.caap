; stdlib/lib/test_sequence.caap — in-language tests for lib/sequence.

;; @area: collections
;; @kind: unit
;; @slow: false
(use stdlib.lib.test assert_eq)
(use stdlib.lib.collections.sequence
  map filter fold reverse find any? all? take drop count join
  length empty? first last sum contains? map_indexed range
  zip sort_by prepend concat pairs
  flat_map flatten index_of min_by max_by min max unique partition
  take_while drop_while
  reduce scan chunk windows enumerate)

(do
  (assert_eq (sum (map (range 1 4) (lambda (x) (int_mul x 2)))) 12 "map+sum")
  (assert_eq (length (filter (range 0 10) (lambda (x) (lt x 5)))) 5 "filter+length")
  (assert_eq (fold (range 1 5) 0 (lambda (a x) (int_add a x))) 10 "fold sum 1..4")
  (assert_eq (first (reverse (range 1 4))) 3 "reverse+first")
  (assert_eq (sum (take (range 1 100) 3)) 6 "take")
  (assert_eq (sum (drop (range 1 5) 2)) 7 "drop")
  (assert_eq (any? (range 1 4) (lambda (x) (eq x 2))) true "any?")
  (assert_eq (all? (range 1 4) (lambda (x) (lt x 10))) true "all?")
  (assert_eq (find (range 1 5) (lambda (x) (lt 2 x))) 3 "find")
  (assert_eq (count (range 1 6) (lambda (x) (lt x 3))) 2 "count")
  (assert_eq (contains? (range 1 4) 2) true "contains? yes")
  (assert_eq (contains? (range 1 4) 9) false "contains? no")
  (assert_eq (length (range 1 4)) 3 "length")
  (assert_eq (empty? (list_of)) true "empty? yes")
  (assert_eq (empty? (range 1 2)) false "empty? no")
  (assert_eq (first (range 5 9)) 5 "first")
  (assert_eq (last (range 5 9)) 8 "last")
  (assert_eq (join (list_of "a" "b" "c") ",") "a,b,c" "join")
  (assert_eq (sum (map_indexed (range 10 13) (lambda (x i) (int_add x i)))) 36 "map_indexed")
  (assert_eq (first (prepend 9 (range 1 3))) 9 "prepend head")
  (assert_eq (sum (prepend 9 (range 1 3))) 12 "prepend keeps rest")
  (assert_eq (sum (concat (range 1 3) (range 10 12))) 24 "concat")
  (assert_eq (size (pairs (list_of "a" 1 "b" 2))) 2 "pairs count")
  (assert_eq (get (get (pairs (list_of "a" 1 "b" 2)) 1) 0) "b" "pairs key")
  (assert_eq (size (pairs (list_of "a" 1 "odd"))) 1 "pairs drops odd tail")
  (assert_eq (size (zip (range 0 3) (range 5 8))) 3 "zip")
  (assert_eq (first (sort_by (list_of 3 1 2) (lambda (x) x))) 1 "sort_by")
  ; enrichment
  (assert_eq (sum (flat_map (range 1 4) (lambda (x) (list_of x x)))) 12 "flat_map")
  (assert_eq (sum (flatten (list_of (list_of 1 2) (list_of 3)))) 6 "flatten")
  (assert_eq (index_of (list_of 10 20 30) 20) 1 "index_of hit")
  (assert_eq (index_of (list_of 10 20) 99) -1 "index_of miss")
  (assert_eq (min (list_of 5 2 8 1)) 1 "min")
  (assert_eq (max (list_of 5 2 8 1)) 8 "max")
  (assert_eq (min_by (list_of -3 1 -5) (lambda (x) (if (lt x 0) (int_sub 0 x) x))) 1 "min_by abs")
  (assert_eq (length (unique (list_of 1 2 2 3 1 3))) 3 "unique")
  (assert_eq (length (get (partition (range 0 6) (lambda (x) (lt x 3))) 0)) 3 "partition yes")
  (assert_eq (length (get (partition (range 0 6) (lambda (x) (lt x 3))) 1)) 3 "partition no")
  (assert_eq (sum (take_while (list_of 1 2 3 9 1) (lambda (x) (lt x 5)))) 6 "take_while")
  (assert_eq (sum (drop_while (list_of 1 2 9 3) (lambda (x) (lt x 5)))) 12 "drop_while")
  ; reduce — no seed; first element seeds the fold
  (assert_eq (reduce (list_of 1 2 3 4) (lambda (a x) (int_add a x))) 10 "reduce sum")
  (assert_eq (reduce (list_of 7) (lambda (a x) (int_add a x))) 7 "reduce singleton -> that element")
  (assert_eq (reduce (list_of) (lambda (a x) (int_add a x))) null "reduce empty -> null")
  ; scan — running accumulations, length n+1, head is init
  (assert_eq (size (scan (list_of 1 2 3) (lambda (a x) (int_add a x)) 0)) 4 "scan length n+1")
  (assert_eq (get (scan (list_of 1 2 3) (lambda (a x) (int_add a x)) 0) 0) 0 "scan head is init")
  (assert_eq (last (scan (list_of 1 2 3) (lambda (a x) (int_add a x)) 0)) 6 "scan last is full fold")
  (assert_eq (get (scan (list_of 1 2 3) (lambda (a x) (int_add a x)) 0) 2) 3 "scan running mid")
  (assert_eq (size (scan (list_of) (lambda (a x) (int_add a x)) 5)) 1 "scan empty -> [init]")
  (assert_eq (get (scan (list_of) (lambda (a x) (int_add a x)) 5) 0) 5 "scan empty head is init")
  ; chunk — partition; last may be shorter
  (assert_eq (size (chunk (range 0 7) 3)) 3 "chunk count with remainder")
  (assert_eq (size (get (chunk (range 0 7) 3) 0)) 3 "chunk full block size")
  (assert_eq (size (get (chunk (range 0 7) 3) 2)) 1 "chunk remainder block shorter")
  (assert_eq (size (chunk (range 0 6) 3)) 2 "chunk even split")
  (assert_eq (size (chunk (list_of) 3)) 0 "chunk empty seq")
  (assert_eq (size (chunk (range 0 3) 0)) 0 "chunk non-positive n -> empty")
  ; windows — sliding windows of size n
  (assert_eq (size (windows (range 0 5) 3)) 3 "windows count = n-k+1")
  (assert_eq (size (get (windows (range 0 5) 3) 0)) 3 "windows each is size n")
  (assert_eq (get (get (windows (range 0 5) 3) 1) 0) 1 "windows second starts at index 1")
  (assert_eq (size (windows (range 0 2) 3)) 0 "windows n>len -> empty")
  ; enumerate — [index element] pairs
  (assert_eq (size (enumerate (list_of "a" "b" "c"))) 3 "enumerate count")
  (assert_eq (get (get (enumerate (list_of "a" "b" "c")) 2) 0) 2 "enumerate index")
  (assert_eq (get (get (enumerate (list_of "a" "b" "c")) 2) 1) "c" "enumerate element")
  (assert_eq (size (enumerate (list_of))) 0 "enumerate empty")
  true)
