; stdlib/lib/test_prelude.caap — the prelude is one usable surface.

;; @area: semantics
;; @kind: unit
;; @slow: false
(use stdlib.lib.test assert_eq assert_true)
(use stdlib.lib.core.prelude
  map fold some? none? deep_eq abs ok? make_error error?
  some option_map option_unwrap_or ok err unwrap map_ok and_then gcd
  error_code error_message
  compose pipe identity approx_eq)

(do
  (assert_eq (fold (map (list_of 1 2 3) (lambda (x) (int_mul x x))) 0 int_add)
    14 "sequence names work")
  (assert_true (deep_eq (list_of 1) (list_of 1)) "equal names work")
  (assert_eq (abs -5) 5 "math names work")
  (assert_true (error? (make_error "x" "m" null)) "error names work")
  ; the option/result families are reachable through the prelude
  (assert_eq (option_unwrap_or (option_map (some 5) (lambda (x) (int_add x 1))) 0)
    6 "option family via prelude")
  (assert_eq (unwrap (map_ok (ok 5) (lambda (x) (int_mul x 2)))) 10
    "result map_ok via prelude")
  (assert_eq (unwrap (and_then (ok 3) (lambda (x) (ok (int_add x 1))))) 4
    "result and_then via prelude")
  (assert_eq (gcd 12 18) 6 "math gcd via prelude")
  (assert_eq (error_code (err "io.read" "boom")) "io.read"
    "result error_code via prelude")
  (assert_eq (error_message (err "io.read" "boom")) "boom"
    "result error_message via prelude")
  ; functional combinators reachable through the prelude
  (assert_eq ((compose (lambda (x) (int_add x 1)) (lambda (x) (int_mul x 2))) 5) 11
    "functional compose via prelude")
  (assert_eq ((pipe (lambda (x) (int_add x 1)) (lambda (x) (int_mul x 2))) 5) 12
    "functional pipe via prelude")
  (assert_eq (identity 42) 42 "functional identity via prelude")
  ; float approx_eq reachable through the prelude
  (assert_true (approx_eq 1.0 1.0000001 0.001) "float approx_eq via prelude")
  true)
