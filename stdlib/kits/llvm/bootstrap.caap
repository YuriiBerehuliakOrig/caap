            module)))
      "impure"
      false)
    (register-helper
      kit-root
      "_emit-lowered-function-v1"
      (lambda (module lowered diagnostics)
        (bind (
          (copy (get kit-root "_copy" null))
          (emit-expression-v1
            (get kit-root "_emit-expression-v1" null))
          (new-function (get kit-root "new-function" null))
          (new-block (get kit-root "new-block" null))
          (instruction-return
            (get kit-root "instruction-return" null))
          (new-temp-state
            (get kit-root "new-temp-state" null))
          (map-function-signature
            (get kit-root "map-function-signature" null))
          (make-diagnostic
            (get kit-root "_make-diagnostic" null))
          (build-emit-env-v1
            (get kit-root "_build-emit-env-v1" null))
          (append-globals-v1
            (get kit-root "_append-globals-v1" null))
          (append-externals-unique-v1
            (get kit-root "_append-externals-unique-v1" null))
          (signature
            (map-function-signature
              (get-any lowered "result_type" null)
              (get-any lowered "params" (list-of))))
        )
          (if (eq signature null)
            (do
              (append
                diagnostics
                (make-diagnostic
                  (get-any lowered "decl" null)
                  "caap.llvm.error.unsupported_type_mapping"
                  "llvm codegen could not map the function signature to LLVM"
                  "entry.signature"))
              null)
            (bind (
              (function
                (assoc
                  (new-function
                    (get-any lowered "symbol" null)
                    (get-any signature "result" null)
                    (copy (get-any signature "params" (list-of))))
                  "caap_result_type"
                  (get-any lowered "result_type" null)))
              (block (new-block "entry"))
              (temp-state (new-temp-state))
              (emit-env (build-emit-env-v1 signature))
            )
              (do
                (assoc
                  temp-state
                  "string_index"
                  (length (get-any module "globals" (list-of))))
                (bind (
                  (result-operand
                    (emit-expression-v1
                      (get-any lowered "body" null)
                      emit-env
                      temp-state
                      (get-any block "instructions" (list-of))))
                )
                  (if (eq result-operand null)
                    (do
                      (append
                        diagnostics
                        (make-diagnostic
                          (get-any lowered "decl" null)
                          "caap.llvm.error.unsupported_expression_kind"
                          "llvm codegen could not emit the lowered expression"
                          "body"))
                      null)
                    (bind (
                      (control-result?
                        (and
                          (value-is-map result-operand)
                          (eq (get-any result-operand "kind" null) "control_result")))
                      (return-block
                        (if control-result?
                          (get-any result-operand "block" block)
                          block))
                      (return-operand
                        (if control-result?
                          (get-any result-operand "operand" null)
                          result-operand))
                    )
                      (if (eq return-operand null)
                        null
                        (do
                          (append
                            (get-any return-block "instructions" (list-of))
                            (instruction-return
                              (get-any signature "result" null)
                              return-operand))
                          (append (get-any function "blocks" (list-of)) block)
                          (each
                            (get-any temp-state "blocks" (list-of))
                            (lambda (extra-block)
                              (append (get-any function "blocks" (list-of)) extra-block)))
                          (append (get-any module "functions" (list-of)) function)
                          (append-globals-v1
                            module
                            (get-any temp-state "globals" (list-of)))
                          (append-externals-unique-v1
                            module
                            (get-any temp-state "externals" (list-of)))
                          signature))))))))))
      "impure"
      false)
    (register-helper
      kit-root
      "emit-unit-ll"
      (lambda (unit contract)
        (bind (
          (copy (get kit-root "_copy" null))
          (make-diagnostic
            (get kit-root "_make-diagnostic" null))
          (new-module (get kit-root "new-module" null))
          (map-function-signature
            (get kit-root "map-function-signature" null))
          (render-module
            (get kit-root "render-module" null))
          (resolve-entry-list-v1
            (get kit-root "_resolve-entry-list-v1" null))
          (build-call-targets-v1
            (get kit-root "_build-call-targets-v1" null))
          (lower-entry-list-v1
            (get kit-root "_lower-entry-list-v1" null))
          (map-contract-externals-v1
            (get kit-root "_map-contract-externals-v1" null))
          (append-externals-unique-v1
            (get kit-root "_append-externals-unique-v1" null))
          (emit-lowered-function-v1
            (get kit-root "_emit-lowered-function-v1" null))
          (entries (resolve-entry-list-v1 contract))
          (call-targets
            (build-call-targets-v1 contract entries))
          (lowered-summary
            (lower-entry-list-v1 unit contract entries call-targets))
          (lowered-functions
            (get-any lowered-summary "functions" (list-of)))
          (diagnostics
            (copy (get-any lowered-summary "diagnostics" (list-of))))
          (supported
            (copy
              (get-any lowered-summary "supported_subset" (list-of))))
          (first-lowered
            (get-any lowered-summary "first" null))
          (diagnostic-result
            (lambda (result-llvm-type)
              (assoc-many
                (map-of)
                "module"
                  (new-module (get-any contract "module" "module"))
                "decl"
                  (if (eq first-lowered null)
                    null
                    (get-any first-lowered "decl" null))
                "symbol"
                  (if (eq first-lowered null)
                    null
                    (get-any first-lowered "symbol" null))
                "text" ""
                "functions" (list-of)
                "diagnostics" diagnostics
                "supported_subset" supported
                "result_llvm_type" result-llvm-type)))
        )
          (if (not (eq (length diagnostics) 0))
            (diagnostic-result null)
            (bind (
              (module
                (new-module (get-any contract "module" "module")))
              (mapped-externals
                (map-contract-externals-v1 contract))
            )
              (if (eq mapped-externals null)
                (do
                  (append
                    diagnostics
                    (make-diagnostic
                      null
                      "caap.llvm.error.unsupported_type_mapping"
                      "llvm codegen could not map one or more external function signatures to LLVM"
                      "entry.externals"))
                  (diagnostic-result null))
                (do
                  (append-externals-unique-v1 module mapped-externals)
                  (each lowered-functions
                    (lambda (fn)
                      (emit-lowered-function-v1 module fn diagnostics)))
                  (if (not (eq (length diagnostics) 0))
                    (diagnostic-result null)
                    (bind (
                      (first-signature
                        (if (eq first-lowered null)
                          null
                          (map-function-signature
                            (get-any first-lowered "result_type" null)
                            (get-any first-lowered "params" (list-of)))))
                    )
                      (assoc-many
                        (map-of)
                        "module" module
                        "decl"
                          (if (eq first-lowered null)
                            null
                            (get-any first-lowered "decl" null))
                        "symbol"
                          (if (eq first-lowered null)
                            null
                            (get-any first-lowered "symbol" null))
                        "text" (render-module module)
                        "functions"
                          (copy (get-any module "functions" (list-of)))
                        "diagnostics" diagnostics
                        "supported_subset" supported
                        "result_llvm_type"
                          (if (eq first-signature null)
                            null
                            (get-any first-signature "result" null)))))))))))
      "pure"
      true)
    (get kit-root "emit-unit-ll" null)))

(ctfe-compiler-execute-bootstrap-files
  compiler
  (list-of "bootstrap_source.caap" "bootstrap_root_contract.caap"))
